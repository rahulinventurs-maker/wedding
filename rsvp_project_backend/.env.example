# Copy this file to .env and fill in your values
# The backend reads these on startup

# Django
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=true
ALLOWED_HOSTS=*

# Database — use DATABASE_URL for a full connection string
# or set individual DB_* vars below
DATABASE_URL=postgresql://lucifer:password123@127.0.0.1:5432/RSVP_PLATFORM

# Individual DB vars (used only if DATABASE_URL is not set)
# DB_NAME=RSVP_PLATFORM
# DB_USER=lucifer
# DB_PASSWORD=password123
# DB_HOST=127.0.0.1
# DB_PORT=5432

# CORS
CORS_ALLOW_ALL_ORIGINS=true
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
CORS_PREFLIGHT_MAX_AGE=1
